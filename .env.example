# Credenciales de Supabase — copiá este archivo a ".env" y completá los valores.
# Los encontrás en: Supabase → tu proyecto → Project Settings → API.
# En Vite, las vars expuestas al frontend deben empezar con VITE_.

# Project URL (ej. https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=

# Clave "anon public" (es segura para el frontend; la seguridad la da RLS).
VITE_SUPABASE_ANON_KEY=
